{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "mwebbers/laravel-code-commons",
    "description": "Shared Laravel/Livewire conventions: typed mixed-narrowing (Json), reusable stable sortable-table and pagination concerns + TableRow DTO, a lazy-table skeleton, and a SCOPE<->test coverage checker.",
    "keywords": ["laravel", "livewire", "commons", "scope-driven", "structure"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.8",
        "livewire/livewire": "^4.3"
    },
    "require-dev": {
        "infection/infection": "^0.34",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^11.1",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "Mwebbers\\LaravelCodeCommons\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mwebbers\\LaravelCodeCommons\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        },
        "platform": {
            "php": "8.3.0"
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "lint": "pint --test",
        "analyse": "phpstan analyse --memory-limit=1G",
        "infection": [
            "Composer\\Config::disableProcessTimeout",
            "infection --threads=4"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
